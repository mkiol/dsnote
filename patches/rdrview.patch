+++ rdrview-patched/CMakeLists.txt	2026-06-27 16:03:54.379967176 +0200
@@ -0,0 +1,45 @@
+cmake_minimum_required(VERSION 3.13)
+
+project(rdrview C)
+
+set(git_commit "93c3c59e61868f3de76984d59c272b9bc6af0159")
+set(sources_dir "${PROJECT_SOURCE_DIR}/src")
+
+string(APPEND CMAKE_C_FLAGS " -DNDEBUG -O2 -Wall -Wextra -fno-strict-aliasing")
+
+add_library(rdrview_api STATIC 
+  rdrview_api.c
+  ${sources_dir}/content.c
+  ${sources_dir}/iterator.c
+  ${sources_dir}/node.c
+  ${sources_dir}/prep_article.c
+  ${sources_dir}/readability.c
+  ${sources_dir}/readerable.c
+  ${sources_dir}/regex.c
+  ${sources_dir}/rdrview.c)
+  
+include(FindPkgConfig)
+
+pkg_search_module(libxml2 REQUIRED libxml-2.0)
+list(APPEND deps_libs ${libxml2_LIBRARIES})
+list(APPEND includes ${libxml2_INCLUDE_DIRS})
+
+target_link_libraries(rdrview_api
+  ${libxml2_LIBRARIES}
+)
+
+target_include_directories(rdrview_api PUBLIC
+  ${sources_dir}
+  ${PROJECT_BINARY_DIR}
+  ${libxml2_INCLUDE_DIRS}
+)
+
+configure_file(version.h.in version.h)
+
+set_target_properties(rdrview_api PROPERTIES PUBLIC_HEADER "rdrview_api.h")
+
+install(
+  TARGETS rdrview_api
+  LIBRARY DESTINATION lib
+  ARCHIVE DESTINATION lib
+  PUBLIC_HEADER DESTINATION include)
diff -ruN -x '.*' rdrview-org/rdrview_api.c rdrview-patched/rdrview_api.c
--- rdrview-org/rdrview_api.c	1970-01-01 01:00:00.000000000 +0100
+++ rdrview-patched/rdrview_api.c	2026-06-26 22:23:59.141740994 +0200
@@ -0,0 +1,206 @@
+#include "rdrview_api.h"
+
+#include <ctype.h>
+#include <libxml/HTMLparser.h>
+#include <libxml/HTMLtree.h>
+#include <stdio.h>
+#include <string.h>
+
+#include "rdrview.h"
+
+#define RDRVIEW_NODE_STACK_SIZE 1024
+
+#define RDRVIEW_LOG(message) \
+    if (logger_cb) {         \
+        logger_cb(message);  \
+    }
+
+static size_t extract_text(xmlNodePtr root, char* buf, size_t buf_size) {
+    if (buf_size == 0 || buf == NULL || root == NULL) {
+        return 0;
+    }
+
+    xmlNodePtr stack[RDRVIEW_NODE_STACK_SIZE];
+    int top = 0;
+    stack[top++] = root;
+
+    size_t written = 0;
+    int first_text = 1;
+
+    while (top > 0) {
+        if (top >= RDRVIEW_NODE_STACK_SIZE) {
+            break;  // stack is full, abort
+        }
+
+        xmlNodePtr node = stack[--top];
+
+        for (xmlNodePtr child = node->children; child != NULL;
+             child = child->next) {
+            if (child->type == XML_TEXT_NODE && child->content != NULL) {
+                char* content = (char*)child->content;
+                size_t content_len = strlen(content);
+
+                // trim leading whitespace
+                size_t start = 0;
+                while (start < content_len &&
+                       isspace((unsigned char)content[start])) {
+                    start++;
+                }
+                // trim trailing whitespace
+                size_t end = content_len;
+                while (end > start &&
+                       isspace((unsigned char)content[end - 1])) {
+                    end--;
+                }
+                size_t trimmed_len = end - start;
+
+                if (trimmed_len > 0) {
+                    // add a space before the text
+                    if (!first_text) {
+                        if (written + 1 < buf_size) {
+                            buf[written++] = ' ';
+                        } else {
+                            buf[buf_size - 1] = '\0';
+                            return written;
+                        }
+                    } else {
+                        first_text = 0;
+                    }
+
+                    if (written + trimmed_len + 1 <= buf_size) {
+                        memcpy(buf + written, content + start, trimmed_len);
+                        written += trimmed_len;
+                    } else {
+                        buf[buf_size - 1] = '\0';
+                        return written;
+                    }
+                }
+            }
+
+            if (child->name &&
+                xmlStrcmp(child->name, (const xmlChar*)"a") == 0) {
+                continue;
+            }
+
+            if (child->type == XML_ELEMENT_NODE) {
+                if (top < RDRVIEW_NODE_STACK_SIZE) {
+                    stack[top++] = child;
+                } else {
+                    break;  // stack is full, abort
+                }
+            }
+        }
+    }
+
+    if (written < buf_size) {
+        buf[written] = '\0';
+    } else if (buf_size > 0) {
+        buf[buf_size - 1] = '\0';
+    }
+
+    return written;
+}
+
+static char* write_str_to_buf(char* dst, char* src, size_t* max_size) {
+    size_t written = 0;
+    size_t content_len = 0;
+
+    if (src == NULL || dst == NULL || max_size == NULL) {
+        return dst;
+    }
+
+    content_len = strlen(src) + 2;  // \n + \0
+    if (content_len < *max_size) {
+        memcpy(dst, src, content_len - 2);
+        dst[content_len - 2] = '\n';
+        dst[content_len - 1] = '\0';
+        written += (content_len - 1);
+    }
+
+    *max_size = *max_size - written;
+
+    return dst + written;
+}
+
+size_t rdrview_extract(char* input, size_t input_size, char* output,
+                       size_t output_max_size, logger_cb_t logger_cb,
+                       unsigned int opts) {
+    htmlDocPtr doc = NULL;
+    htmlNodePtr article = NULL;
+    size_t written_size = 0;
+    xmlBufferPtr xml_buf = NULL;
+    char* output_orig = NULL;
+
+    output_orig = output;
+
+    // default flags
+    options = (struct options){0};
+    options.flags |= OPT_STRIP_UNLIKELY;
+    options.flags |= OPT_WEIGHT_CLASSES;
+    options.flags |= OPT_CLEAN_CONDITIONALLY;
+    options.enc = "UTF-8";
+
+    LIBXML_TEST_VERSION
+
+    doc = parse_mapped_file(input, input_size);
+    if (!doc) {
+        RDRVIEW_LOG("xml parse failed");
+        goto cleanup;
+    }
+
+    init_regexes();
+
+    article = parse(doc);
+    if (!article) {
+        RDRVIEW_LOG("parse failed");
+
+        if (opts & RDRVIEW_OPT_TEXT_ONLY) {
+            htmlNodePtr root = xmlDocGetRootElement(doc);
+            written_size = extract_text(root, output, output_max_size);
+        }
+
+        goto cleanup;
+    }
+
+    if (opts & RDRVIEW_OPT_TEXT_ONLY) {
+        if (opts & RDRVIEW_OPT_INSERT_METADATA) {
+            output = write_str_to_buf(output, metadata.title, &output_max_size);
+        }
+
+        written_size = extract_text(article, output, output_max_size);
+    } else {
+        xml_buf = xmlBufferCreate();
+        if (!xml_buf) {
+            RDRVIEW_LOG("xmlBufferCreate failed");
+            goto cleanup;
+        }
+        htmlNodeDump(xml_buf, doc, article);
+        if (xmlBufferLength(xml_buf) <= 0) {
+            RDRVIEW_LOG("xmlBufferLength is zero");
+            goto cleanup;
+        }
+
+        size_t size_to_copy = xmlBufferLength(xml_buf);
+        if (size_to_copy > output_max_size) {
+            size_to_copy = output_max_size;
+        }
+
+        memcpy(output, xmlBufferContent(xml_buf), size_to_copy);
+        written_size += size_to_copy;
+    }
+
+cleanup:
+    if (xml_buf) {
+        xmlBufferFree(xml_buf);
+    }
+    if (article) {
+        free_node(article);
+    }
+    if (doc) {
+        free_doc(doc);
+    }
+
+    xmlCleanupParser();
+
+    return written_size + (output - output_orig);
+}
